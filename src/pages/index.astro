---
import Layout from "@layouts/Layout.astro"
import HeroShowcase from "@components/HeroShowcase"
import { defaultLocale } from "@/i18n/translations"

const GITHUB_URL = "https://github.com/ZB-ZettaByte/stepwise"
const APP_URL = "/stepwise/app"

const stats = ["45+ Algorithms", "Step by Step", "DSA Focused", "Open Source"]

// Deep-link each category to a representative algorithm (all real /[algorithm] routes).
const categories = [
  {label: "Concepts", href: "/stepwise/big-o-notation"},
  { label: "Data Structures", href: "/stepwise/linked-list" },
  { label: "Sorting", href: "/stepwise/bubble-sort" },
  { label: "Searching", href: "/stepwise/binary-search" },
  { label: "Graphs", href: "/stepwise/bfs" },
  { label: "Dynamic Programming", href: "/stepwise/fibonacci-dp" },
  { label: "Backtracking", href: "/stepwise/n-queens" },
  { label: "Divide and Conquer", href: "/stepwise/tower-of-hanoi" },
  { label: "Math", href: "/stepwise/sieve-of-eratosthenes" },
]

const title = "Stepwise — Learn Algorithms the Way You Think"
const description =
  "Step-by-step visualizations for Data Structures and Algorithms Free forever."
---

<Layout locale={defaultLocale} title={title} description={description} scrollable>
  <!-- Navbar -->
  <header class="sticky top-0 z-50 border-b border-slate-200 bg-white">
    <nav class="mx-auto flex h-24 max-w-[1500px] items-center justify-between px-7">
      <a
        href="/stepwise/"
        class="font-heading text-[1.65rem] font-semibold tracking-tight text-slate-950"
        aria-label="Stepwise — Home"
      >
        Stepwise
      </a>

      <div class="flex items-center gap-3">
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="View Stepwise on GitHub"
          class="press flex h-12 w-12 items-center justify-center rounded-lg text-slate-500 hover:bg-slate-100 hover:text-slate-950"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path>
          </svg>
        </a>

        <a
          href={APP_URL}
          class="press rounded-lg border border-slate-200 bg-white px-7 py-3.5 text-xl font-medium text-slate-900 shadow-sm hover:border-amber-400 hover:bg-amber-50 hover:text-amber-700"
        >
          Launch App
        </a>
      </div>
    </nav>
  </header>

  <main id="main-content" class="bg-white text-slate-950">
    <!-- Hero -->
    <section class="relative mx-auto flex min-h-[calc(100svh-6rem)] max-w-[1500px] items-center px-7 py-20 md:py-24">
      <div class="grid w-full items-center gap-16 lg:grid-cols-[0.95fr_1.05fr] lg:gap-20 xl:gap-24">
        <div>
          <h1 class="font-display text-6xl font-bold leading-[1.02] tracking-tight text-slate-950 sm:text-7xl md:text-8xl lg:text-[7.25rem]">
            <span class="block">See Every</span>
            <span class="block whitespace-nowrap">Algorithm Run</span>
          </h1>

          <p class="mt-9 max-w-2xl text-2xl leading-relaxed text-slate-600 md:text-[1.75rem]">
            Step-by-step algorithm visualizations with real Python and C++ code
          </p>

          <div class="mt-12">
            <a
              href={APP_URL}
              class="press inline-flex items-center gap-3 rounded-lg bg-amber-400 px-8 py-4 text-xl font-semibold text-slate-950 shadow-sm hover:bg-amber-500"
            >
              Start Learning
              <span>→</span>
            </a>
          </div>
        </div>

        <!-- Animated bar chart from the app welcome screen -->
        <div class="landing-showcase-direct">
          <HeroShowcase client:load />
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="border-y border-slate-200 bg-slate-50">
      <div
        class="mx-auto flex max-w-[1500px] flex-wrap items-center justify-center gap-x-6 gap-y-4 px-7 py-10 text-xl text-slate-600"
      >
        {
          stats.map((stat, i) => (
            <>
              <span>{stat}</span>
              {i < stats.length - 1 && <span class="text-slate-300">·</span>}
            </>
          ))
        }
      </div>
    </section>

    <!-- Categories -->
    <section class="mx-auto grid min-h-[60svh] max-w-[1500px] items-center gap-12 px-7 py-28 md:grid-cols-[0.35fr_0.65fr] md:py-36">
      <div>
        <p class="text-lg uppercase tracking-[0.24em] text-amber-600">Explore</p>
        <h2 class="mt-4 font-display text-5xl font-bold leading-tight tracking-tight text-slate-950 md:text-6xl">
          Choose a topic
        </h2>
        <p class="mt-5 max-w-md text-xl leading-relaxed text-slate-500">
          Jump into a category, then step through the first algorithm in that path.
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {
          categories.map((cat, i) => (
            <a
              href={cat.href}
              class="explore-link group flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-5 py-5 text-slate-800 transition-colors duration-150 hover:border-amber-400 hover:bg-amber-50"
            >
              <span class="flex min-w-0 items-center gap-4">
                <span class="font-mono text-sm text-slate-400">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="truncate text-2xl font-medium md:text-3xl">{cat.label}</span>
              </span>
              <span class="text-2xl text-amber-500 transition-transform duration-150 group-hover:translate-x-1">
                →
              </span>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-slate-200 bg-white">
    <div class="mx-auto max-w-[1500px] px-7 py-18 text-center text-xl text-slate-500">
      Built by Sai Rithwik Kukunuri
    </div>
  </footer>
</Layout>

<style>
  /* Press feedback — buttons feel responsive to touch. */
  .press {
    transition-property: color, background-color, border-color;
    transition-duration: 150ms;
    transition-timing-function: cubic-bezier(0.23, 1, 0.32, 1);
  }

  .explore-link {
    transition-property: color, background-color, border-color, transform;
    transition-duration: 160ms;
    transition-timing-function: cubic-bezier(0.23, 1, 0.32, 1);
  }

  .explore-link:hover {
    transform: translateY(-2px);
  }

  .explore-link:active {
    transform: translateY(0) scale(0.99);
  }

  /* Let the hero chart render directly without an extra visual container. */
  .landing-showcase-direct :global(.landing-showcase > div) {
    padding-inline: 0;
  }
  .landing-showcase-direct :global(.landing-showcase > div > div:first-child) {
    max-width: none;
  }
</style>
